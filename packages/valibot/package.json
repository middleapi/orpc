{
  "name": "@orpc/valibot",
  "type": "module",
  "version": "2.0.0-beta.11",
  "license": "MIT",
  "homepage": "https://orpc.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/middleapi/orpc.git",
    "directory": "packages/valibot"
  },
  "keywords": [
    "orpc",
    "valibot"
  ],
  "sideEffects": false,
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "type:check": "tsc -b"
  },
  "peerDependencies": {
    "valibot": ">=1.0.0"
  },
  "dependencies": {
    "@orpc/json-schema": "workspace:*",
    "@valibot/to-json-schema": "^1.5.0"
  },
  "devDependencies": {
    "valibot": "^1.4.1",
    "zod": "^4.4.3"
  }
}
