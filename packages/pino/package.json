{
  "name": "@orpc/pino",
  "type": "module",
  "version": "2.0.0-beta.11",
  "license": "MIT",
  "homepage": "https://orpc.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/middleapi/orpc.git",
    "directory": "packages/pino"
  },
  "keywords": [
    "orpc",
    "pino"
  ],
  "sideEffects": false,
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
