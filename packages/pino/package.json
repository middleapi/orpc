    "type:check": "tsc -b"
  },
  "peerDependencies": {
    "pino": ">=10.1.0"
  },
  "dependencies": {
    "@orpc/client": "workspace:*",
    "@orpc/server": "workspace:*",
    "@orpc/shared": "workspace:*",
    "@standardserver/core": "^0.0.25"
  },
  "devDependencies": {
    "pino": "^10.3.1"
  }
}
