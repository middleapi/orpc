{
  "name": "@orpc/publisher",
  "type": "module",
  "version": "2.0.0-beta.1",
  "license": "MIT",
  "homepage": "https://orpc.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/middleapi/orpc.git",
    "directory": "packages/publisher"
  },
  "keywords": [
    "orpc"
  ],
  "sideEffects": false,
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./memory": {
        "types": "./dist/adapters/memory.d.mts",
        "import": "./dist/adapters/memory.mjs",
        "default": "./dist/adapters/memory.mjs"
      },
      "./redis": {
        "types": "./dist/adapters/redis.d.mts",
        "import": "./dist/adapters/redis.mjs",
        "default": "./dist/adapters/redis.mjs"
      },
      "./upstash": {
        "types": "./dist/adapters/upstash.d.mts",
        "import": "./dist/adapters/upstash.mjs",
        "default": "./dist/adapters/upstash.mjs"
      }
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./memory": "./src/adapters/memory.ts",
    "./redis": "./src/adapters/redis.ts",
    "./upstash": "./src/adapters/upstash.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "type:check": "tsc -b"
  },
  "peerDependencies": {
    "@upstash/redis": ">=1.35.6",
    "redis": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "dependencies": {
    "@orpc/client": "workspace:*",
    "@orpc/shared": "workspace:*",
    "@standardserver/core": "^0.0.25"
  },
  "devDependencies": {
    "@upstash/redis": "^1.38.0",
    "redis": "^6.0.0"
  }
}
