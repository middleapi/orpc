    "@orpc/next": "latest",
    "@orpc/openapi": "latest",
    "@orpc/opentelemetry": "latest",
    "@orpc/publisher": "latest",
    "@orpc/server": "latest",
    "@orpc/tanstack-query": "latest",
    "@orpc/zod": "latest",
