{
  "name": "base",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "nuxt build",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/db/seed.ts",
    "db:studio": "drizzle-kit studio --port 4984",
    "dev": "nuxt dev",
    "dev:trigger": "trigger dev",
    "deploy:trigger": "trigger deploy",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck && pnpm typecheck:scripts",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "worktree:up": "bash ./scripts/worktree-up.sh"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.14",
