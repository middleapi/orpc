    "@orpc/client": "^1.14.4",
    "@orpc/contract": "^1.14.4",
    "@orpc/json-schema": "^1.14.4",
    "@orpc/openapi": "^1.14.4",
    "@orpc/openapi-client": "^1.14.4",
    "@orpc/server": "^1.14.4",
    "@orpc/tanstack-query": "^1.14.4",
    "@orpc/zod": "^1.14.4",
    "@tanstack/vue-query": "^5.101.0",
    "@trigger.dev/sdk": "4.4.6",
    "@vueuse/nuxt": "^14.3.0",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.7",
    "postgres": "^3.4.9",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "knip": "^6.15.0",
    "trigger.dev": "4.4.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.3"
