{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; ./node_modules/.bin/eslint --no-warn-ignored --max-warnings=0 --fix \"$f\"; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Running eslint --fix"
          }
        ]
      }
    ]
  }
}
